# ==============================================================================
# Biblioteca API — Variáveis de Ambiente
# ==============================================================================
# Copie este arquivo para .env e ajuste os valores.
# O .env é lido automaticamente pelo docker-compose e nunca deve ser commitado.
#
# Uso:
#   cp .env.example .env
#   # edite .env com seus valores
#   docker compose up -d
# ==============================================================================

# Senha do banco PostgreSQL.
# Em produção, use uma senha forte (mínimo 16 caracteres aleatórios).
# Em dev local pode deixar 'postgres' mesmo.
POSTGRES_PASSWORD=postgres
